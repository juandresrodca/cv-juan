---
const allWriteups = await Astro.glob('../pages/projects/*.md');
const htbWriteups = allWriteups.filter(
    (writeup) => writeup.frontmatter.tags && writeup.frontmatter.tags.includes("HackTheBox")
);
const sortedWriteups = htbWriteups.sort((a, b) => {
    const dateA = new Date(a.frontmatter.publishDate);
    const dateB = new Date(b.frontmatter.publishDate);
    return dateB.getTime() - dateA.getTime();
});
const staticProjects = [
    {
        title: "DorkCraft",
        description: "Transforms plain-English queries into precise Google dork operators for OSINT, academic research, and public information discovery. Built with Astro and FastAPI.",
        tags: ["OSINT", "Astro", "FastAPI", "Python"],
        link: "https://juandresrodca.github.io/DorkCraft/",
        github: "https://github.com/juandresrodca/DorkCraft",
        emoji: "🔍",
        gradient: "from-cyan-500 to-blue-600",
        linkLabel: "Live Site"
    },
    {
        title: "Phishing Detection Simulator",
        description: "A Python CLI tool simulating SOC analyst workflows — scans emails for phishing indicators, scores risk from 0–100 (LOW/MEDIUM/HIGH), and exports JSON/CSV reports.",
        tags: ["Python", "Cybersecurity", "SOC", "CLI Tool"],
        link: "/cv-juan/projects/phishing-detection-sim/",
        github: "https://github.com/juandresrodca/Phishing-Detection-Sim",
        emoji: "🎣",
        gradient: "from-orange-500 to-red-600",
        linkLabel: "View Details"
    },
    {
        title: "Job Application Tracker",
        description: "A comprehensive web application designed to help job seekers manage their application journey by tracking submissions, follow-ups, responses, and interview progress.",
        tags: ["Web Application", "Job Search", "Productivity"],
        link: "/cv-juan/projects/job-application-tracker/",
        github: "https://github.com/juandresrodca/job-application-tracker",
        emoji: "📋",
        gradient: "from-blue-500 to-cyan-600",
        linkLabel: "View Details"
    },
    {
        title: "C# MVC Web Application",
        description: "Full-stack web application built with ASP.NET Core MVC, implementing user authentication, CRUD operations, and responsive design patterns.",
        tags: ["C#", "ASP.NET Core", "SQL Server"],
        link: "/cv-juan/projects/mvc-webapp/",
        github: "https://github.com/juandresrodca/cv-juan",
        emoji: "💻",
        gradient: "from-purple-500 to-pink-600",
        linkLabel: "View Details"
    },
    {
        title: "Home Security Lab",
        description: "Personal cybersecurity lab environment using VirtualBox, Kali Linux, and vulnerable VMs for practicing penetration testing and digital forensics.",
        tags: ["Kali Linux", "VirtualBox", "Metasploit"],
        link: "https://github.com/juandresrodca/cv-juan",
        github: "https://github.com/juandresrodca/cv-juan",
        emoji: "🔒",
        gradient: "from-red-500 to-orange-600",
        linkLabel: "View Details"
    }
];
---
<section id="projects" class="scroll-reveal py-20 bg-dark-800 bg-opacity-40">
    <div class="container mx-auto px-6">
        <h2 class="section-title">My Projects and Write-ups</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
            {sortedWriteups.map((writeup) => (
                <div class="card glow-card tilt-card group hover:scale-105 transition-transform duration-300">
                    <div class={`h-48 bg-gradient-to-br ${writeup.frontmatter.gradient || 'from-green-500 to-blue-600'} rounded-lg mb-6 flex items-center justify-center text-6xl`}>
                        {writeup.frontmatter.emoji || '🎯'}
                    </div>
                    <h3 class="text-2xl font-bold mb-4 text-primary-400">{writeup.frontmatter.title}</h3>
                    <p class="text-gray-300 mb-6">{writeup.frontmatter.description}</p>
                    <div class="flex flex-wrap gap-2 mb-6">
                        {writeup.frontmatter.tags.map((tag: string) => (
                            <span class="bg-primary-600/20 text-primary-400 px-2 py-1 rounded text-sm">{tag}</span>
                        ))}
                    </div>
                    <div class="flex space-x-4">
                        <a href={writeup.url} class="btn-primary text-sm">Read Write-up</a>
                        {writeup.frontmatter.github && (
                            <a href={writeup.frontmatter.github} target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">GitHub</a>
                        )}
                    </div>
                </div>
            ))}
            {staticProjects.map((project) => (
                <div class="card glow-card tilt-card group hover:scale-105 transition-transform duration-300">
                    <div class={`h-48 bg-gradient-to-br ${project.gradient} rounded-lg mb-6 flex items-center justify-center text-6xl`}>
                        {project.emoji}
                    </div>
                    <h3 class="text-2xl font-bold mb-4 text-primary-400">{project.title}</h3>
                    <p class="text-gray-300 mb-6">{project.description}</p>
                    <div class="flex flex-wrap gap-2 mb-6">
                        {project.tags.map((tag: string) => (
                            <span class="bg-primary-600/20 text-primary-400 px-2 py-1 rounded text-sm">{tag}</span>
                        ))}
                    </div>
                    <div class="flex space-x-4">
                        <a href={project.link} target={project.link.startsWith('http') ? '_blank' : '_self'} rel="noopener noreferrer" class="btn-primary text-sm">{project.linkLabel}</a>
                        {project.github && (
                            <a href={project.github} target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">GitHub</a>
                        )}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
