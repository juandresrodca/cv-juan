 <section id="home" class="min-h-screen flex items-center justify-center relative bg-transparent">
        <div class="container mx-auto px-6 text-center z-10">
            <div class="max-w-4xl mx-auto">
                <!-- Typewriter effect greeting -->
                <div class="animate-fade-in">
                    <h1 class="text-6xl md:text-8xl font-bold mb-6 text-gradient typewriter-header">
                        <span id="typed-text">Hi, I'm Juan</span><span class="cursor">|</span>
                    </h1>
                </div>

                <!-- Animated subtitle with delay -->
                <div class="animate-slide-up" style="animation-delay: 0.3s;">
                    <p class="text-xl md:text-2xl mb-8 text-gray-300 leading-relaxed">
                        <span class="text-primary-400 font-semibold">IT Systems Administrator & Support Specialist</span><br>
                        With 14+ years of experience in enterprise infrastructure,<br>
                        cloud environments, and IT service management.
                    </p>
                </div>

                <!-- CTA buttons with delay -->
                <div class="animate-slide-up space-x-4" style="animation-delay: 0.6s;">
                    <a href="#projects" class="btn-primary inline-block">
                        View My Work
                    </a>
                    <a href="#contact" class="btn-secondary inline-block">
                        Get In Touch
                    </a>
                </div>

                <!-- Scroll indicator -->
                <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce">
                    <a href="#about" class="text-gray-400 hover:text-primary-400 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

<style>
    .cursor {
        animation: blink 0.7s infinite;
        color: #00ff41;
        font-weight: bold;
    }

    @keyframes blink {
        0%, 50% { opacity: 1; }
        51%, 100% { opacity: 0; }
    }
</style>

<script>
    const phrases = [
        "Hi, I'm Juan",
        "IT Systems Administrator",
        "Cybersecurity Enthusiast",
        "Penetration Tester"
    ];

    let phraseIdx = 0;
    let charIdx = phrases[0].length;
    let isDeleting = false;
    const el = document.getElementById('typed-text');

    function type() {
        const current = phrases[phraseIdx];

        if (isDeleting) {
            el.textContent = current.substring(0, charIdx--);
        } else {
            el.textContent = current.substring(0, charIdx++);
        }

        // Completed typing a phrase
        if (!isDeleting && charIdx > current.length) {
            setTimeout(() => {
                isDeleting = true;
                type();
            }, 1500);
            return;
        }

        // Completed deleting a phrase
        if (isDeleting && charIdx < 0) {
            isDeleting = false;
            phraseIdx = (phraseIdx + 1) % phrases.length;
        }

        const speed = isDeleting ? 30 : 80;
        setTimeout(type, speed);
    }

    // Start typing animation when component loads
    if (el) {
        type();
    }
</script>
