---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  /** BASE_URL-relative or absolute path to the social-share image. */
  image?: string;
  /** Open Graph type — use "article" for blog posts. */
  type?: string;
}

const {
  title,
  description = "Juan Rodriguez - IT Support Specialist transitioning to Cybersecurity",
  image = `${import.meta.env.BASE_URL}og-banner.png`,
  type = "website",
} = Astro.props;

// Social scrapers (LinkedIn, Twitter, Slack) require absolute URLs.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <meta name="description" content={description} />
    <meta name="author" content="Juan Rodriguez" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#0f2056" />

    <!-- Open Graph (LinkedIn, Facebook, Slack previews) -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Juan Rodriguez — IT Systems Administrator & Cybersecurity Specialist" />
    <meta property="og:site_name" content="Juan Rodriguez — Portfolio" />
    <meta property="og:locale" content="en_IE" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <!-- SVG favicon (Chrome, Firefox, Edge) — falls back to .ico for Safari -->
    <link rel="icon" type="image/svg+xml"  href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/x-icon"   href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <!-- iOS home-screen icon uses the SVG scaled to 180×180 -->
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  </head>
  <body class="font-inter bg-dark-900 text-white overflow-x-hidden">
    <!-- Scroll Progress Bar -->
    <div class="scroll-progress"></div>

    <slot />

    <script>
      // Import statement for animations.js is here in the original,
      // but for standalone HTML, we'll inline the script content later
      // or ensure it's available via a global scope.
      // For Astro, this imports the client-side script.
      import '../scripts/animations.js';
    </script>
  </body>
</html>
